{
  "name": "stellar-uzima-backend",
  "version": "1.0.0",
  "description": "Backend API for Stellar Uzima - Healthcare & Financial Inclusion through Blockchain for African Communities",
  "author": "Stellar Uzima Team",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:cov": "jest --config jest.config.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.js --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "typeorm migration:run -d src/database/data-source.ts",
    "migration:run": "npm run migrate",
    "migrate:create": "typeorm migration:create",
    "seed": "ts-node src/database/seeders/run-seeders.ts",
    "seed:db": "npm run seed",
    "seed:refresh": "npm run migrate:rollback && npm run migrate && npm run seed",
    "migrate:rollback": "typeorm migration:revert -d src/database/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.0",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "otplib": "^12.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.10.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "stellar-sdk": "^11.0.0",
    "twilio": "^6.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.40.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prettier": "^3.0.0",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0",
    "typescript-eslint": "^8.62.1"
  }
}
